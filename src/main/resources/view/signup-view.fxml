<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="550.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.fedelesh.flowersalon.presentation.controller.SignUpController">
  <children>
    <AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="550.0" prefWidth="600.0">
      <children>
        <Button fx:id="sendCodeButton" layoutX="322.0" layoutY="355.0" onAction="#onSendCodeClick" text="Отримати код" />

        <Button layoutX="80.0" layoutY="430.0" onAction="#onRegisterClick" prefWidth="440.0" text="Зареєструватися" />

        <Hyperlink layoutX="239.0" layoutY="486.0" onAction="#onBackToLoginClick" text="Вже є акаунт? Увійти" />

        <Label layoutX="232.0" layoutY="26.0" text="Реєстрація">
          <font>
            <Font size="28.0" />
          </font>
        </Label>

        <Label layoutX="80.0" layoutY="66.0" text="Ім'я" />
        <Label fx:id="firstNameErrorLabel" layoutX="80.0" layoutY="111.0" textFill="RED" />

        <Label layoutX="320.0" layoutY="66.0" text="Прізвище" />
        <Label fx:id="lastNameErrorLabel" layoutX="320.0" layoutY="111.0" textFill="RED" />

        <Label layoutX="80.0" layoutY="134.0" text="Email" />
        <Label fx:id="emailErrorLabel" layoutX="80.0" layoutY="179.0" textFill="RED" />

        <Label layoutX="79.0" layoutY="200.0" text="Телефон" />
        <Label fx:id="phoneErrorLabel" layoutX="80.0" layoutY="245.0" textFill="RED" />

        <Label layoutX="81.0" layoutY="266.0" text="Пароль" />
        <Label fx:id="passwordErrorLabel" layoutX="81.0" layoutY="311.0" textFill="RED" />

        <Label layoutX="80.0" layoutY="335.0" text="Код підтвердження" />
        <Label fx:id="codeErrorLabel" layoutX="80.0" layoutY="380.0" textFill="RED" />

        <Label fx:id="statusLabel" layoutX="81.0" layoutY="399.0" prefWidth="440.0" />

        <PasswordField fx:id="passwordField" layoutX="81.0" layoutY="286.0" prefWidth="440.0" promptText="Password" />

        <ProgressIndicator fx:id="progressIndicator" layoutX="437.0" layoutY="358.0" prefHeight="30.0" prefWidth="30.0" visible="false" />

        <TextField fx:id="firstNameField" layoutX="80.0" layoutY="86.0" prefWidth="200.0" promptText="First Name" />
        <TextField fx:id="lastNameField" layoutX="320.0" layoutY="86.0" prefWidth="200.0" promptText="Last Name" />
        <TextField fx:id="emailField" layoutX="80.0" layoutY="154.0" prefWidth="440.0" promptText="example: mail@gmail.com" />
        <TextField fx:id="phoneField" layoutX="80.0" layoutY="220.0" prefWidth="440.0" promptText="+380..." />
        <TextField fx:id="codeField" layoutX="80.0" layoutY="355.0" prefWidth="230.0" />
      </children>
    </AnchorPane>
  </children>
</StackPane>
