<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.text.Font?>
<GridPane xmlns:fx="http://javafx.com/fxml/1"
  alignment="CENTER"
  hgap="10"
  vgap="10"
  xmlns="http://javafx.com/javafx/21"
  fx:controller="com.fedelesh.flowersalon.presentation.controller.LoginController">

  <Button GridPane.columnSpan="2"
    GridPane.halignment="CENTER"
    GridPane.rowIndex="6"
    onAction="#onLoginClick"
    prefWidth="120"
    text="Увійти"
    fx:id="loginButton">
    <font>
      <Font size="17.0"/>
    </font>
  </Button>

  <Hyperlink GridPane.columnSpan="2"
    GridPane.halignment="CENTER"
    GridPane.rowIndex="7"
    onAction="#onOpenSignUpClick"
    text="Нема акаунту? Зареєструйтесь"/>

  <Label GridPane.columnSpan="2"
    GridPane.halignment="CENTER"
    GridPane.rowIndex="3"
    text="Пароль"/>

  <Label GridPane.columnSpan="2"
    GridPane.halignment="CENTER"
    GridPane.rowIndex="5"
    alignment="CENTER"
    prefWidth="400"
    textFill="RED"
    fx:id="errorLabel"/>

  <Label GridPane.columnSpan="2" GridPane.halignment="CENTER" GridPane.rowIndex="0" text="Увійти">
    <font>
      <Font size="28.0"/>
    </font>
  </Label>

  <Label GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.halignment="CENTER"
    GridPane.rowIndex="1"
    text="Пошта"/>

  <PasswordField GridPane.columnSpan="2"
    GridPane.halignment="CENTER"
    GridPane.rowIndex="4"
    prefWidth="240"
    promptText="Введіть пароль"
    fx:id="passwordField"/>

  <TextField GridPane.columnSpan="2"
    GridPane.halignment="CENTER"
    GridPane.rowIndex="2"
    prefWidth="240"
    promptText="example@mail.com"
    fx:id="emailField"/>

  <padding>
    <Insets bottom="20" left="20" right="20" top="20"/>
  </padding>

</GridPane>