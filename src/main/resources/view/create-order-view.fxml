<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
  prefHeight="760"
  prefWidth="1300"
  styleClass="page"
  stylesheets="@/styles/app.css"
  xmlns="http://javafx.com/javafx/21"
  fx:controller="com.fedelesh.flowersalon.presentation.controller.CreateOrderController">

  <center>
    <SplitPane dividerPositions="0.38, 0.68">
      <items>

        <VBox spacing="10">
          <Button onAction="#handleBack" styleClass="button,secondary-button" text="Назад"/>

          <TabPane VBox.vgrow="ALWAYS">
            <tabs>

              <Tab closable="false" text="Квіти">
                <VBox spacing="10">
                  <Button onAction="#handleAddFlower" styleClass="button,primary-button" text="Додати квітку"/>

                  <TableView VBox.vgrow="ALWAYS" fx:id="flowersTableView">
                    <columns>
                      <TableColumn prefWidth="80" text="Зображення" fx:id="flowerImageColumn"/>
                      <TableColumn prefWidth="120" text="Назва" fx:id="flowerNameColumn"/>
                      <TableColumn prefWidth="100" text="Колір" fx:id="flowerColorColumn"/>
                      <TableColumn prefWidth="80" text="Ціна" fx:id="flowerPriceColumn"/>
                    </columns>
                  </TableView>
                </VBox>
              </Tab>

              <Tab closable="false" text="Букети">
                <VBox spacing="10">
                  <Button onAction="#handleAddBouquet" styleClass="button,primary-button" text="Додати букет"/>

                  <TableView VBox.vgrow="ALWAYS" fx:id="bouquetsTableView">
                    <columns>
                      <TableColumn prefWidth="80" text="Зображення" fx:id="bouquetImageColumn"/>
                      <TableColumn prefWidth="120" text="Назва" fx:id="bouquetNameColumn"/>
                      <TableColumn prefWidth="220" text="Опис" fx:id="bouquetDescriptionColumn"/>
                      <TableColumn prefWidth="80" text="Ціна" fx:id="bouquetPriceColumn"/>
                    </columns>
                  </TableView>
                </VBox>
              </Tab>

              <Tab closable="false" text="Аксесуари">
                <VBox spacing="10">
                  <Button onAction="#handleAddAccessory" styleClass="button,primary-button" text="Додати аксесуар"/>

                  <TableView VBox.vgrow="ALWAYS" fx:id="accessoriesTableView">
                    <columns>
                      <TableColumn prefWidth="80" text="Зображення" fx:id="accessoryImageColumn"/>
                      <TableColumn prefWidth="120" text="Назва" fx:id="accessoryNameColumn"/>
                      <TableColumn prefWidth="120" text="Тип" fx:id="accessoryTypeColumn"/>
                      <TableColumn prefWidth="80" text="Ціна" fx:id="accessoryPriceColumn"/>
                    </columns>
                  </TableView>
                </VBox>
              </Tab>

            </tabs>
          </TabPane>

          <VBox spacing="8">
            <Button maxWidth="Infinity"
              onAction="#handleCreateOrder"
              styleClass="button,primary-button"
              text="Створити замовлення"
              fx:id="createOrderButton"/>

            <HBox spacing="10" styleClass="total-box">
              <Label styleClass="subtle-label" text="Всього:"/>
              <Label fx:id="totalLabel"/>
            </HBox>
            <Label styleClass="section-title" text="Інформація користувача"/>
            <TextField promptText="Номер телефону" fx:id="phoneField"/>
            <TextField promptText="Стиль" fx:id="styleField"/>
            <TextField promptText="Бажаний колір" fx:id="colorField"/>

            <TextField promptText="Ім'я" fx:id="firstNameField"/>

            <TextField promptText="Призвіще" fx:id="lastNameField"/>
          </VBox>

          <padding>
            <Insets bottom="15" left="15" right="15" top="15"/>
          </padding>
        </VBox>

        <VBox spacing="10">
          <Button maxWidth="Infinity"
            onAction="#handleRemoveItem"
            styleClass="button,danger-button"
            text="Прибрати вибране"/>

          <Label styleClass="section-title" text="Поточне замовлення"/>

          <TableView VBox.vgrow="ALWAYS" fx:id="orderItemsTableView">
            <columns>
              <TableColumn prefWidth="90" text="Тип" fx:id="orderTypeColumn"/>
              <TableColumn prefWidth="140" text="Назва" fx:id="orderNameColumn"/>
              <TableColumn prefWidth="60" text="К-сть" fx:id="orderQuantityColumn"/>
              <TableColumn prefWidth="80" text="Ціна" fx:id="orderPriceColumn"/>
              <TableColumn prefWidth="80" text="Всього" fx:id="orderTotalColumn"/>
            </columns>
          </TableView>

          <padding>
            <Insets bottom="15" left="15" right="15" top="15"/>
          </padding>
        </VBox>

        <VBox spacing="10">
          <Label styleClass="section-title" text="Робоча поверхня"/>

          <Pane VBox.vgrow="ALWAYS"
            prefHeight="600"
            prefWidth="350"
            styleClass="workspace"
            fx:id="bouquetWorkspace"/>

          <padding>
            <Insets bottom="15" left="15" right="15" top="15"/>
          </padding>
        </VBox>

      </items>
    </SplitPane>
  </center>

</BorderPane>
